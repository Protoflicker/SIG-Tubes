# Base URL untuk REST API. Default "/api/v1" cocok untuk:
#   - Dev: Vite proxy (lihat vite.config.js) ke localhost:8000
#   - Production: Vercel rewrite /api/* ke serverless function
# Set ke URL absolut hanya bila backend di-host terpisah, contoh:
#   VITE_API_BASE=https://api.example.com/api/v1
VITE_API_BASE=/api/v1
