# =================== SUPABASE (production) ===================
# Ambil dari Supabase Dashboard → Project Settings → Database → Connection String
# Pakai mode "Transaction" (port 6543) untuk serverless. Driver: psycopg.
#
# DATABASE_URL=postgresql+psycopg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# CORS_ORIGINS=https://your-app.vercel.app
# ADMIN_TOKEN=ganti-dengan-string-rahasia-acak  # untuk endpoint /api/v1/admin/seed
